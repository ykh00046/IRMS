# IRMS Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application environment: development | production
IRMS_ENV=development

# Session secret key (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
IRMS_SESSION_SECRET=

# Session max age in seconds (default: 28800 = 8 hours)
IRMS_SESSION_MAX_AGE=28800

# Require explicit session secret (default: true in production)
IRMS_REQUIRE_SESSION_SECRET=true

# Data directory path (default: ./data)
IRMS_DATA_DIR=./data

# Seed demo data on startup (default: true in development, false in production)
# WARNING: Inserts users with well-known passwords. Never enable in production.
IRMS_SEED_DEMO_DATA=false
