# Python cache
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# Runtime databases and WAL files
data/*.db
data/*.db-shm
data/*.db-wal

# 루트에 둔 옛 잉크 프로젝트(Program-estimation) 산출물 — 절대 커밋하지 않음
/*.db
/*.xlsx

# 사내 실데이터(한글 엑셀 수기 원본) — 루트 이탈로 /*.xlsx 규칙이 커버하지 않으므로 명시
excel/legacy/

# Auto-generated DB backups (kept locally, never pushed)
backups/*.db

# Temporary runtime/test data
.tmp-tests/
data/__tmp_*/
data/audit_ui_test_db/
tmp_*/
tmpivkqp8nt/
tmp_e2e_artifacts/
tmp_e2e_runtime/

# Local editor state
.idea/
.vscode/

# Secrets / environment variables (never push API keys)
.env
.env.*

# Cloudflare Tunnel local secrets (real config + credentials)
cloudflared/config.yml
cloudflared/*.json

# bkit runtime
.bkit/

# Playwright MCP logs
.playwright-mcp/

# WSL backup
.venv-wsl-backup-*/

# Misc (루트에 두는 스크린샷·캡처 이미지)
*.png
*.jpg
*.jpeg
.pytest-tmp/
.pytest_tmp/
.tmp-tests/
.coverage
.gstack/

# 서명 합성 필수 자산(이미지 무시 예외)
!src/resources/signature/
!src/resources/signature/*.png
!src/resources/signature/*.jpg
!src/resources/signature/*.jpeg

# 저울 에이전트 빌드 산출물
scale_agent/dist/
scale_agent/build/

# ERP 품목 마스터 원본(임포트 소스 — 커밋 금지, data/master/ 보관 예정)
code*.xlsx
